[user]
	email = iain@dillingham.me.uk
	name = Iain Dillingham
[core]
	editor = vi
	excludesfile = ~/.gitignore
	pager = most
[commit]
	template = ~/.gitmessage
	gpgsign = true
[push]
	default = simple
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
